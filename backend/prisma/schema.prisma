// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  coins     Float      @default(1000.0)
  positions Position[]
}

model Market {
  id         String         @id @default(uuid())
  question   String
  status     Status         @default(OPEN)
  resolvesAt DateTime
  outcome    Outcome?
  pool       LiquidityPool?
  positions  Position[]
}

// AMM liquidity pool tracking YES/NO reserves for each market.
// Constant-product invariant: yesReserve * noReserve = k
model LiquidityPool {
  id         String  @id @default(uuid())
  marketId   String  @unique
  yesReserve Float   @default(1000.0)
  noReserve  Float   @default(1000.0)

  market     Market  @relation(fields: [marketId], references: [id])
}

model Position {
  id       String  @id @default(uuid())
  userId   String
  marketId String
  outcome  Outcome
  shares   Float   @default(0.0)

  user     User    @relation(fields: [userId], references: [id])
  market   Market  @relation(fields: [marketId], references: [id])

  @@unique([userId, marketId, outcome])
}

enum Status {
  OPEN
  CLOSED
  RESOLVED
}

enum Outcome {
  YES
  NO
}