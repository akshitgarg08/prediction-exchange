// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  password    String
  coins       Float      @default(1000.0)
  lockedCoins Float      @default(0.0)
  orders      Order[]
  positions   Position[]
}

model Market {
  id         String   @id @default(uuid())
  question   String
  status     Status   @default(OPEN)
  resolvesAt DateTime
  outcome    Outcome?
  orders     Order[]
  trades     Trade[]
}

model Order {
  id               String      @id @default(uuid())
  userId           String
  marketId         String
  type             OrderType   // BUY, SELL
  outcome          Outcome     // YES, NO
  price            Float       
  quantity         Int
  remainingQty     Int         
  status           OrderStatus @default(OPEN)
  createdAt        DateTime    @default(now())
  
  user             User        @relation(fields: [userId], references: [id])
  market           Market      @relation(fields: [marketId], references: [id])
  makerTrades      Trade[]     @relation("MakerOrder")
  takerTrades      Trade[]     @relation("TakerOrder")
}

model Trade {
  id           String   @id @default(uuid())
  marketId     String
  makerOrderId String
  takerOrderId String
  price        Float
  quantity     Int
  createdAt    DateTime @default(now())

  market       Market   @relation(fields: [marketId], references: [id])
  makerOrder   Order    @relation("MakerOrder", fields: [makerOrderId], references: [id])
  takerOrder   Order    @relation("TakerOrder", fields: [takerOrderId], references: [id])
}

model Position {
  id           String  @id @default(uuid())
  userId       String
  marketId     String
  outcome      Outcome
  quantity     Int     @default(0)
  averagePrice Float   @default(0.0)

  user         User    @relation(fields: [userId], references: [id])
  @@unique([userId, marketId, outcome])
}

enum Status {
  OPEN
  CLOSED
  RESOLVED
}

enum Outcome {
  YES
  NO
}

enum OrderType {
  BUY
  SELL
}

enum OrderStatus {
  OPEN
  PARTIAL
  FILLED
  CANCELLED
}